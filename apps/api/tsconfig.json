{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "moduleResolution": "node",
    "ignoreDeprecations": "5.0",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": "../../",
    "paths": {
      "@banking-crm/types": ["../../packages/types/src/index.ts"],
      "@banking-crm/database": ["../../packages/database/src/index.ts"],
      "@banking-crm/ai": ["../../packages/ai/src/index.ts"]
    }
  },
  "include": [
    "src/**/*",
    "../../packages/types/src/**/*",
    "../../packages/database/src/**/*",
    "../../packages/ai/src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "../../packages/ai/src/**/__tests__/**/*",
    "../../packages/ai/src/**/*.test.ts",
    "../../packages/ai/src/**/*.spec.ts"
  ]
}
